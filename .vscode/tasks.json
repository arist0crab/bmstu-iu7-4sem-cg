{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build project",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-I${workspaceFolder}/inc",
                "-I/usr/include/qt6",
                "-I/usr/include/qt6/QtCore", 
                "-L/usr/lib64/qt6",
                "${workspaceFolder}/src/*.cpp",
                "-lQt6Core",
                "${file}",
                "-o",
                "${workspaceFolder}/main_cli"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Сборка всех cpp файлов из src"
        }
    ],
    "version": "2.0.0"
}